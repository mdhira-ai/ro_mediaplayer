{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ro_mediaplayer",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ro_mediaplayer",
        "width": 900,
        "height": 501,
        "resizable": true,
        "fullscreen": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; video-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPCACHE/**", "$APPLOCALDATA/**", "$APPDOCUMENTS/**", "$APPTEMP/**", "$APPCONFIG/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
